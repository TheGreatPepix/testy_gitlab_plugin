--- /dev/null
+++ b/frontend/src/features/test-plan/run-autotests/run-autotests.tsx
@@ -0,0 +1,56 @@
+import { memo } from "react"
+import { useTranslation } from "react-i18next"
+
+import { useGetPlanRunStatusQuery, useRunGitlabTestsMutation } from "entities/plugin/api"
+
+import PlayIcon from "shared/assets/yi-icons/play.svg?react"
+import { useAntdModals } from "shared/hooks"
+import { Button } from "shared/ui"
+
+interface Props {
+  testPlan: TestPlan
+}
+
+export const RunAutotests = memo(({ testPlan }: Props) => {
+  const { t } = useTranslation()
+  const { antdNotification } = useAntdModals()
+  const [runGitlabTests, { isLoading }] = useRunGitlabTestsMutation()
+  const { data: runStatus } = useGetPlanRunStatusQuery(testPlan.id)
+
+  const handleRun = async () => {
+    try {
+      await runGitlabTests({ plan: testPlan.id, plans: [testPlan.id] }).unwrap()
+      antdNotification.success("run-tests", {
+        description: t("Pipeline triggered"),
+      })
+    } catch (error) {
+      const apiError = error as {
+        data?: { detail?: string; missing?: Record<string, number[]> }
+        message?: string
+      }
+      const missing = apiError.data?.missing ? ` ${JSON.stringify(apiError.data.missing)}` : ""
+      const detail = apiError.data?.detail || apiError.message || t("Failed to run tests")
+      antdNotification.error("run-tests", {
+        description: `${detail}${missing}`,
+      })
+    }
+  }
+
+  if (!runStatus?.can_run) {
+    return null
+  }
+
+  return (
+    <Button
+      id="run-autotests-test-plan"
+      icon={<PlayIcon width={16} height={16} />}
+      onClick={handleRun}
+      color="secondary-linear"
+      disabled={isLoading}
+    >
+      {t("Run Autotests")}
+    </Button>
+  )
+})
+
+RunAutotests.displayName = "RunAutotests"
